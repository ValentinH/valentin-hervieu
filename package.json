  },
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "resume:setup": "bunx playwright install chromium",
    "resume:dev": "vite --config vite.resume.config.ts --host 127.0.0.1 --open /src/resume/index.html",
    "resume:pdf": "bun scripts/generate-resume-pdf.ts",
    "format": "oxfmt . '!src/routeTree.gen.ts'",
    "format:check": "oxfmt --check . '!src/routeTree.gen.ts'",
    "lint": "oxlint . --react-plugin --jsx-a11y-plugin --import-plugin",
    "lint:ts": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/alegreya-sans-sc": "^5.2.7",
    "@fontsource/roboto": "^5.2.10",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-router": "^1.169.1",
    "@tanstack/react-start": "^1.167.62",
    "@unpic/react": "^1.0.2",
    "@vercel/analytics": "^2.0.1",
    "animated-scroll-to": "^2.3.2",
    "clsx": "^2.1.1",
    "motion": "^12.38.0",
    "nitro": "^3.0.260429-beta",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-easy-crop": "^5.5.7",
    "react-easy-sort": "^1.8.0",
    "react-image-gallery": "^2.1.2",
    "react-intersection-observer": "^10.0.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "unpic": "^4.2.2"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "^1.167.32",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "packageManager": "bun@1.3.3"
